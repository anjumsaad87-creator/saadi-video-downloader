{
  "name": "videodl-server",
  "version": "1.0.0",
  "description": "Saadi Video Downloader (SVD) - Video Downloader API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npm run build:frontend",
    "build:frontend": "cd frontend && npm install --include=dev && npm run build",
    "postinstall": "node scripts/ensure-ytdlp.js",
    "setup": "npm install && npm run build:frontend"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "yt-dlp-exec": "^1.0.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
