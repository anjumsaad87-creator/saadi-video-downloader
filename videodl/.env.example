# ── Saadi Video Downloader (SVD) Environment Variables ───────────────────
# Copy this to .env and fill in your values

# Server port (Hostinger typically sets this automatically via PORT env var)
PORT=3001

# Frontend URL (your domain, for CORS)
FRONTEND_URL=https://yourdomain.com

# Node environment
NODE_ENV=production

# Optional: YouTube cookies file path (helps with some restricted videos)
# YTDLP_COOKIES=/home/user/cookies.txt

# Optional: Download cookies.txt from a private URL on startup (recommended for Render)
# Host it somewhere private (Basic Auth) and provide the URL + Authorization header.
# Example:
#   YTDLP_COOKIES_URL=https://svd-private.example.com/cookies.txt
#   YTDLP_COOKIES_AUTH=Basic <base64(username:password)>
# YTDLP_COOKIES_URL=
# YTDLP_COOKIES_AUTH=

# Optional: Proxy (if your server IP is blocked by YouTube)
# YTDLP_PROXY=http://proxy:port
