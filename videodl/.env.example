# ── Saadi Video Downloader (SVD) Environment Variables ───────────────────
# Copy this to .env and fill in your values

# Server port (Hostinger typically sets this automatically via PORT env var)
PORT=3001

# Frontend URL (your domain, for CORS)
FRONTEND_URL=https://yourdomain.com

# Node environment
NODE_ENV=production

# Optional: YouTube cookies file path (helps with some restricted videos)
# YTDLP_COOKIES=/home/user/cookies.txt

# Optional: Proxy (if your server IP is blocked by YouTube)
# YTDLP_PROXY=http://proxy:port
